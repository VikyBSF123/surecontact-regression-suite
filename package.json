{
  "name": "surecontact-regression-suite",
  "version": "1.0.0",
  "description": "Full regression test suite for SureContact Platform",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "metrics": "node utils/metrics-dashboard.js && open metrics-dashboard/index.html",
    "test:components": "npx playwright test --config=playwright-ct.config.js",
    "test:components:headed": "npx playwright test --config=playwright-ct.config.js --headed",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:mobile": "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:smoke": "npx playwright test --grep @smoke --project=chromium",
    "test:critical": "npx playwright test --grep @critical --project=chromium",
    "test:regression": "npx playwright test --grep @regression",
    "test:api-tag": "npx playwright test --grep @api",
    "test:auth": "npx playwright test tests/auth/",
    "test:dashboard": "npx playwright test tests/dashboard/",
    "test:crm": "npx playwright test tests/crm/",
    "test:campaigns": "npx playwright test tests/campaigns/",
    "test:automations": "npx playwright test tests/automations/",
    "test:forms": "npx playwright test tests/forms/",
    "test:landing-pages": "npx playwright test tests/landing-pages/",
    "test:members": "npx playwright test tests/members/",
    "test:reports": "npx playwright test tests/reports/",
    "test:settings": "npx playwright test tests/settings/",
    "test:connections": "npx playwright test tests/connections/",
    "test:api": "npx playwright test tests/api/",
    "test:visual": "npx playwright test --project=visual",
    "test:visual:update": "npx playwright test --project=visual --update-snapshots",
    "test:a11y": "npx playwright test --project=accessibility",
    "test:mocked": "npx playwright test tests/mocked/ --project=chromium",
    "test:perf": "npx playwright test tests/performance/ --project=chromium",
    "test:security": "npx playwright test tests/security/ --project=chromium",
    "test:isolated": "npx playwright test tests/crm/contacts-isolated.spec.js --project=chromium",
    "report": "npx playwright test && open monocart-report/index.html",
    "report:open": "open monocart-report/index.html",
    "report:playwright": "npx playwright show-report playwright-report",
    "clean": "rm -rf monocart-report playwright-report test-results allure-results allure-report"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --max-warnings=-1",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.48.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "monocart-reporter": "^2.10.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
